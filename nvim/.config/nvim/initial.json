	{
		"key": "z",
		"name": "+Spelling",
		"type": "bindings",
		"bindings": [
			{ "key": "a", "name": "Add word", "type": "command", "command": "zg" },
			{ "key": "f", "name": "Use 1st correction", "type": "command", "command": "1z=" },
			{ "key": "l", "name": "List corrections", "type": "command", "command": "Telescope spell_suggest" },
