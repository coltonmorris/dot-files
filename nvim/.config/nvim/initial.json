				"bindings": [
					{ "key": "b", "name": "Find buffers", "type": "command", "command": "Telescope buffers" },
					{ "key": "c", "name": "Command history", "type": "command", "command": "Telescope command_history" },
					{ "key": "f", "name": "Find file", "type": "command", "command": "Telescope find_files" },
					{ "key": "g", "name": "Live grep", "type": "command", "command": "Telescope live_grep" },
					{ "key": "h", "name": "Find help tags", "type": "command", "command": "Telescope help_tags" },
					{ "key": "q", "name": "Quickfix list", "type": "command", "command": "Telescope quickfix" },
